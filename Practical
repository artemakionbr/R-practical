#MVMR

#we are using the ‘MVMR’ package to estimate the model, however, much of this estimation could also be done within the ‘TwoSampleMR’ package.
#The MVMR package does not store the names of the exposures. In this example;• exposure 1 is HDL-C• exposure 2 is LDL-C• exposure 3 is triglycerides

#Data PREP
#Harmonize Data

mv <- mv_harmonise_data(mv_exp_dat, mv_out_dat, harmonise_strictness = 2)

#format the data for the MVMR package
mv_dat <- format_mvmr(mv$exposure_beta, mv$outcome_beta, mv$exposure_se,
mv$outcome_se, rownames(mv$exposure_beta))

#How many instruments are there for MVMR?

#Test the strength of the SNPs to jointly predict all of the exposures
#As our exposures come from the same dataset, to calculate the conditional F-statistics we need to generate a matrix of the covariance between the error terms in the SNP-exposure
#associations for each exposure. The simplest way to do this is to use the function ‘phenocov_mvmr()’ and phenotypic correlations between the exposures. In this case those
#correlations have been calculated from individual-level UK Biobank data.

pheno_mat <- matrix(c(1, 0.18, -0.35,
0.18, 1, 0.33,
-0.35, 0.33, 1), nrow=3, ncol=3)
gencov <- phenocov_mvmr(pheno_mat, mv$exposure_se)
strength_mvmr(mv_dat, gencov)

#Calculate the MVMR-IVW effect estimate for each exposure
ivw_mvmr(mv_dat, gencov)

#Calculate the heterogeneity Q-statistic for the MVMR model.
pleiotropy_mvmr(mv_dat, gencov)

